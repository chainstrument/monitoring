{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block stylesheets %}
    <style>
        .status-badge { display: inline-block; padding: 0.2em 0.6em; border-radius: 4px; color: #fff; font-size: 0.85em; }
        .status-up { background: #2e7d32; }
        .status-down { background: #c62828; }
        .status-unknown { background: #757575; }
    </style>
{% endblock %}

{% block body %}
    <h1>Dashboard</h1>

    <form method="get">
        <label for="tag-filter">Tag</label>
        <input type="text" id="tag-filter" name="tag" value="{{ tag }}">

        <label for="type-filter">Type</label>
        <select id="type-filter" name="type">
            <option value="">Tous</option>
            {% for choice in types %}
                <option value="{{ choice.value }}" {{ type == choice ? 'selected' }}>{{ choice.label }}</option>
            {% endfor %}
        </select>

        <button type="submit">Filtrer</button>
        {% if tag or type %}
            <a href="{{ path('dashboard_index') }}">Réinitialiser</a>
        {% endif %}
    </form>

    <div id="dashboard-table">
        {% include 'dashboard/_table.html.twig' %}
    </div>
{% endblock %}

{% block javascripts %}
    <script>
        // Rafraîchissement live basique (US-07.3) : pas de Turbo/Mercure pour
        // l'instant (V2), un polling toutes les 12s suffit pour une vue de
        // supervision perso.
        (function () {
            var container = document.getElementById('dashboard-table');
            var refreshUrl = '{{ path('dashboard_refresh') }}?' + window.location.search.replace(/^\?/, '');

            function refresh() {
                fetch(refreshUrl, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                    .then(function (response) { return response.ok ? response.text() : null; })
                    .then(function (html) { if (html) { container.innerHTML = html; } })
                    .catch(function () { /* prochaine tentative dans 12s */ });
            }

            setInterval(refresh, 12000);
        })();
    </script>
{% endblock %}
