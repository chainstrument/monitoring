includes:
    - vendor/phpstan/phpstan-symfony/extension.neon
    - vendor/phpstan/phpstan-doctrine/extension.neon
    - vendor/phpstan/phpstan-doctrine/rules.neon

parameters:
    level: max
    paths:
        - src
        - tests
    symfony:
        containerXmlPath: var/cache/dev/App_KernelDevDebugContainer.xml
    ignoreErrors:
        -
            # Appelée par symfony/runtime via réflexion (convention MicroKernelTrait), jamais en PHP direct.
            message: '#Method App\\Kernel::getAllowedEnvs\(\) is unused\.#'
            path: src/Kernel.php
        -
            # Garde de compatibilité générée par le recipe symfony/test-pack, conservée telle quelle.
            message: '#Call to function method_exists\(\) with .*Dotenv.* and .bootEnv. will always evaluate to true\.#'
            path: tests/bootstrap.php
